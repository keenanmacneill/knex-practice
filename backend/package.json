{
  "name": "knex-practice",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=dev nodemon src/server.js",
    "test-db": "cross-env NODE_ENV=test knex migrate:latest && knex seed:run",
    "start": "cross-env NODE_ENV=prod node src/server.js",
    "migrate": "knex migrate:latest",
    "rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "reset-db": "knex migrate:rollback --all && knex migrate:latest && knex seed:run",
    "migrate-make": "knex migrate:make",
    "seed-make": "knex seed:make"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "knex": "^3.1.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.14"
  }
}
